# Tack environment file, rendered by Ansible from tack/tack.env.j2 at deploy
# time. Secret values come from vault_* variables in
# ansible/inventory/group_vars/all/vault.yml (encrypted); non-secret values come
# from the tack group_vars. Nothing here is hand-edited on the host.

# Container image tag. Production leaves this at latest; QA pins a specific
# branch build via tack_image_tag in group_vars to verify it before merge.
TACK_IMAGE_TAG={{ tack_image_tag | default('latest') }}

# YugabyteDB credentials
YUGABYTE_USER={{ tack_yugabyte_user }}
YUGABYTE_DB={{ tack_yugabyte_db }}
YUGABYTE_PASSWORD={{ tack_yugabyte_password }}

# Meilisearch master key
MEILI_MASTER_KEY={{ tack_meili_master_key }}

# Audit ledger DSNs and passwords.
# Each DSN is a full postgres:// URL pointing at the yugabyte service.
# The password component must match the corresponding _PASSWORD variable
# so that seed-audit-roles can create or rotate the role credentials.
AUDIT_WRITER_PASSWORD={{ tack_audit_writer_password }}
AUDIT_READER_PASSWORD={{ tack_audit_reader_password }}
AUDIT_REDACTOR_PASSWORD={{ tack_audit_redactor_password }}
AUDIT_WRITER_DSN=postgres://tack_audit_writer:{{ tack_audit_writer_password }}@yugabyte:5433/{{ tack_yugabyte_db }}?sslmode=disable
AUDIT_READER_DSN=postgres://tack_audit_reader:{{ tack_audit_reader_password }}@yugabyte:5433/{{ tack_yugabyte_db }}?sslmode=disable
AUDIT_REDACTOR_DSN=postgres://tack_audit_redactor:{{ tack_audit_redactor_password }}@yugabyte:5433/{{ tack_yugabyte_db }}?sslmode=disable

# Path to the Ed25519 audit signing key on the host.
# Generated once per host with:
#   openssl genpkey -algorithm ed25519 -out /etc/tack/audit-signing.pem
# QA and production MUST use separate keys; sharing keys collapses the
# audit ledger's compliance claim.
AUDIT_SIGNING_KEY_PATH={{ tack_audit_signing_key_path }}

# tack-ops sidecar database URL.
# The ops container runs on host networking and connects to the Yugabyte
# YSQL port on the loopback address of the host (port 5433 is published).
TACK_OPS_DATABASE_URL={{ tack_ops_database_url }}

# Logging
LOG_LEVEL={{ tack_log_level | default('debug') }}
LOG_MAX_BACKUPS={{ tack_log_max_backups | default(0) }}
LOG_MAX_AGE_DAYS={{ tack_log_max_age_days | default(0) }}
LOG_MAX_SIZE_MB={{ tack_log_max_size_mb | default(100) }}

# FDB version (must match the Go bindings pin in go.mod and Makefile).
FDB_VERSION={{ tack_fdb_version | default('7.4.6') }}

# HTTP port the app listens on inside the container.
PORT={{ tack_port | default(8000) }}

# Docker IPv6 bridge subnet and gateway, per host. docker-compose.yml reads
# these for networks.default. The NDP proxy prefix (tack_ndp_proxy_prefix) must
# match the subnet.
TACK_DOCKER_V6_SUBNET={{ tack_docker_v6_subnet }}
TACK_DOCKER_V6_GATEWAY={{ tack_docker_v6_gateway }}

# Backup object store (S3-compatible). On QA this is the SeaweedFS LXC on the
# suburban segment. Empty on hosts whose object store is not yet provisioned;
# only the ops backup commands read these, never the request path.
TACK_BACKUP_S3_ENDPOINT={{ tack_backup_s3_endpoint | default('') }}
TACK_BACKUP_S3_ACCESS_KEY_ID={{ tack_backup_s3_access_key | default('') }}
TACK_BACKUP_S3_SECRET_ACCESS_KEY={{ tack_backup_s3_secret_key | default('') }}
TACK_BACKUP_S3_REGION={{ tack_backup_s3_region | default('us-east-1') }}
TACK_BACKUP_S3_BUCKET_MAIN={{ tack_backup_s3_bucket_main | default('tack-backups') }}
TACK_BACKUP_S3_BUCKET_AUDIT={{ tack_backup_s3_bucket_audit | default('tack-audit-archive') }}
