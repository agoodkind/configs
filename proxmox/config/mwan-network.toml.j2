ping_target_ipv4 = "{{ mwan_watchdog_ping_target_ipv4 | default('1.1.1.1') }}"
ping_target_ipv6 = "{{ mwan_watchdog_ping_target_ipv6 | default('2606:4700:4700::1111') }}"
last_deploy_path = "{{ mwan_watchdog_last_deploy_path | default('/var/run/mwan-last-deploy') }}"

{% for iface in mwan_watchdog_wan_interfaces | default([mwan_webpass_iface, mwan_monkeybrains_iface]) %}
[[wan_interfaces]]
name = "{{ iface }}"
{% endfor %}
