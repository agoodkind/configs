{
    "Dhcp6": {
        "interfaces-config": { "interfaces": ["eth0"] },
        "lease-database": { "type": "memfile", "persist": false },
        "preferred-lifetime": 3000,
        "valid-lifetime": 4000,
        "subnet6": [{
            "id": 1,
{% if isp.ia_na %}
            "subnet": "{{ isp.slaac_prefix }}",
            "interface": "eth0",
            "pools": [{ "pool": "{{ isp.ia_na_pool }}" }],
            "pd-pools": [{ "prefix": "{{ isp.pd_prefix | regex_replace('/[0-9]+$', '') }}", "prefix-len": {{ isp.pd_len }}, "delegated-len": {{ isp.pd_len }} }]
{% else %}
            "subnet": "fe80::/10",
            "interface": "eth0",
            "pd-pools": [{ "prefix": "{{ isp.pd_prefix | regex_replace('/[0-9]+$', '') }}", "prefix-len": {{ isp.pd_len }}, "delegated-len": {{ isp.pd_len }} }]
{% endif %}
        }]
    }
}
