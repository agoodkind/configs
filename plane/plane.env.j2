# Plane environment configuration - managed by Ansible, do not edit manually.
# Variable names must match the upstream docker-compose.yml YAML anchors exactly.
# Reference: deployments/cli/community/variables.env in makeplane/plane

APP_DOMAIN={{ plane_domain }}
APP_RELEASE=stable

WEB_REPLICAS=1
SPACE_REPLICAS=1
ADMIN_REPLICAS=1
API_REPLICAS=1
WORKER_REPLICAS=1
BEAT_WORKER_REPLICAS=1
LIVE_REPLICAS=1

LISTEN_HTTP_PORT=80
LISTEN_HTTPS_PORT=443

WEB_URL=https://{{ plane_domain }}
DEBUG=0
CORS_ALLOWED_ORIGINS=https://{{ plane_domain }},https://{{ service_hostname }}
API_BASE_URL=http://api:8000

# Database
PGHOST=plane-db
PGDATABASE=plane
POSTGRES_USER=plane
POSTGRES_PASSWORD={{ plane_db_password }}
POSTGRES_DB=plane
POSTGRES_PORT=5432
PGDATA=/var/lib/postgresql/data
DATABASE_URL=postgresql://plane:{{ plane_db_password }}@plane-db/plane

# Redis
REDIS_HOST=plane-redis
REDIS_PORT=6379
REDIS_URL=redis://plane-redis:6379/

# RabbitMQ
RABBITMQ_HOST=plane-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD={{ plane_rabbitmq_password }}
RABBITMQ_VHOST=plane
AMQP_URL=amqp://plane:{{ plane_rabbitmq_password }}@plane-mq:5672/plane

# TLS (handled externally; leave cert fields blank for reverse-proxy termination)
CERT_ACME_CA=https://acme-v02.api.letsencrypt.org/directory
TRUSTED_PROXIES=0.0.0.0/0
SITE_ADDRESS=:80
CERT_EMAIL=
CERT_ACME_DNS=

# Secret keys
SECRET_KEY={{ plane_secret_key }}
LIVE_SERVER_SECRET_KEY={{ plane_live_secret_key }}

# Object storage (MinIO)
USE_MINIO=1
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY={{ plane_minio_secret_key }}
AWS_S3_ENDPOINT_URL=http://plane-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880
MINIO_ENDPOINT_SSL=0

# API tuning
GUNICORN_WORKERS=1
API_KEY_RATE_LIMIT=60/minute
