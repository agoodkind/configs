# Management Interface - IPv6 only
# Generated by Ansible for {{ hostname }}

[Match]
Name={{ vm_mgmt_iface }}

[Network]
Address={{ vm_mgmt_ipv6 }}/{{ vm_mgmt_ipv6_prefix }}
DNS={{ vm_mgmt_dns_servers }}
Domains={{ vm_mgmt_dns_domain }}
DHCP=no
IPv6AcceptRA=no
{% if vm_mgmt_gateway6 is defined and vm_mgmt_gateway6 %}

[Route]
Gateway={{ vm_mgmt_gateway6 }}
Table={{ vm_mgmt_route_table | default(500) }}

[RoutingPolicyRule]
From={{ vm_mgmt_ipv6 }}
Table={{ vm_mgmt_route_table | default(500) }}
Priority=5
{% endif %}
