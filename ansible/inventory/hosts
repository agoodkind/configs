[all:vars]
ansible_user=root

[local]
localhost ansible_connection=local

# Proxmox hypervisor SSH targets.
# These are real SSH hosts AND parents of LXC/VM guests. Each hypervisor
# also has a matching ansible/inventory/proxmox-<name>.yml dynamic plugin
# that discovers its guests as separate inventory hosts.
[vault_servers]
vault ansible_host=3d06:bad:b01::254 consul_bind_interface=vmbr0

# Suburban Proxmox host. IPv6 is preferred but currently unreachable from
# this controller (3d06:bad:b01:200::1), so SSH uses IPv4 until that path
# is fixed. See docs/infra/INFRA.md.
[suburban_servers]
suburban ansible_host=10.240.0.148

# Shared parent group for both hypervisors. deploy-proxmox.yml targets this.
[proxmox_servers:children]
vault_servers
suburban_servers

# Tack parent group (tack_all) and its children (tack_servers, tack_qa_servers)
# are declared in inventory/group_vars/all/service_mapping.yml under the
# top-level group_children block. The service_mapping plugin creates them at
# parse time, so they do not need INI placeholders here.
