# frozen_string_literal: true

require 'fileutils'

# Local Rake wrappers for the five canonical Ansible playbooks. Run from this
# directory (`ansible/`) or pass --working-dir; `ansible.cfg` here resolves
# inventory automatically.
#
# Vault password file defaults to ~/.config/ansible/vault.pass.
# Override with VAULT_PASS_FILE=... or pass `nopass=1` to skip.

VAULT_PASS_FILE = ENV.fetch('VAULT_PASS_FILE', File.expand_path('~/.config/ansible/vault.pass'))
LOCAL_PLAYBOOKS_DIR = 'playbooks'

CANONICAL_PLAYBOOKS = {
  proxmox:   'deploy-proxmox.yml',
  mwan:      'deploy-mwan.yml',
  failover:  'deploy-mwan-failover.yml',
  opnsense:  'deploy-opnsense.yml',
  testbed:   'deploy-testbed.yml'
}.freeze

##
# Build the ansible-playbook command for a given playbook name.
#
# @param playbook [String] playbook filename relative to playbooks/
# @param extras  [Array<String>] additional ansible-playbook args
# @return [Array<String>] argv ready for `sh`
def ansible_playbook_argv(playbook, extras = [])
  argv = ['ansible-playbook']
  if ENV['nopass'].to_s == '1' || !File.exist?(VAULT_PASS_FILE)
    argv += ['--vault-password-file', VAULT_PASS_FILE] if File.exist?(VAULT_PASS_FILE)
  else
    argv += ['--vault-password-file', VAULT_PASS_FILE]
  end
  argv << "#{LOCAL_PLAYBOOKS_DIR}/#{playbook}"
  argv.concat(extras) if extras && !extras.empty?
  argv
end

##
# Run a canonical playbook with optional --limit and --check passthrough.
#
# Tasks accept rake args: rake proxmox[vault] runs with --limit vault.
# Add :check tasks for --check --diff dry runs.
#
# @param playbook [String] playbook filename
# @param limit    [String, nil] --limit target (e.g. "vault")
# @param check    [Boolean] add --check --diff
# @return [void]
def run_playbook(playbook, limit: nil, check: false)
  extras = []
  extras += ['--limit', limit] if limit && !limit.empty?
  extras += ['--check', '--diff'] if check
  sh(*ansible_playbook_argv(playbook, extras))
end

namespace :deploy do
  CANONICAL_PLAYBOOKS.each do |key, playbook|
    desc "Run #{playbook}; optional rake deploy:#{key}[<limit>]"
    task key, [:limit] do |_t, args|
      run_playbook(playbook, limit: args[:limit])
    end
  end
end

namespace :check do
  CANONICAL_PLAYBOOKS.each do |key, playbook|
    desc "Dry-run #{playbook} with --check --diff; optional rake check:#{key}[<limit>]"
    task key, [:limit] do |_t, args|
      run_playbook(playbook, limit: args[:limit], check: true)
    end
  end
end

namespace :syntax do
  CANONICAL_PLAYBOOKS.each do |key, playbook|
    desc "Syntax-check #{playbook}"
    task key do
      sh 'ansible-playbook', '--syntax-check', "#{LOCAL_PLAYBOOKS_DIR}/#{playbook}"
    end
  end

  desc 'Syntax-check every canonical playbook'
  task all: CANONICAL_PLAYBOOKS.keys.map { |k| "syntax:#{k}" }
end

desc 'Show inventory graph (proves the new layout loads)'
task :inventory do
  sh 'ansible-inventory', '--graph'
end

desc 'Lint canonical playbooks with ansible-lint'
task :lint do
  CANONICAL_PLAYBOOKS.each_value do |pb|
    sh 'ansible-lint', "#{LOCAL_PLAYBOOKS_DIR}/#{pb}"
  end
end

desc 'Help: list canonical playbook shortcuts'
task :help do
  puts 'Ansible canonical playbook shortcuts (local, no remote rsync).'
  puts ''
  puts 'Run a playbook:'
  CANONICAL_PLAYBOOKS.each do |k, v|
    puts format('  rake deploy:%-9s    # %s', k, v)
  end
  puts ''
  puts 'Limit to one host (passes --limit):'
  puts '  rake deploy:proxmox[vault]'
  puts '  rake deploy:mwan[mwan.home.goodkind.io]'
  puts '  rake deploy:failover[mwan_failover_test_servers]'
  puts ''
  puts 'Dry-run (--check --diff):'
  puts '  rake check:proxmox[vault]'
  puts '  rake check:mwan'
  puts ''
  puts 'Syntax-check:'
  puts '  rake syntax:all'
  puts '  rake syntax:opnsense'
  puts ''
  puts 'Inventory shape (read-only):'
  puts '  rake inventory'
  puts ''
  puts 'Set VAULT_PASS_FILE=/path/to/passfile, or nopass=1 to skip vault decryption.'
end

task default: :help
