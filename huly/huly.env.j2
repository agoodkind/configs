HULY_VERSION={{ huly_version }}
DESKTOP_CHANNEL={{ huly_desktop_channel }}
DOCKER_NAME={{ huly_docker_name }}

# Host where the web app is exposed.
HOST_ADDRESS={{ huly_domain }}
SECURE={{ huly_secure }}

# Bind and port for the bundled nginx reverse-proxy.
HTTP_PORT={{ huly_http_port }}
HTTP_BIND={{ huly_http_bind }}

# Huly options.
TITLE={{ huly_title | quote }}
DEFAULT_LANGUAGE={{ huly_default_language | quote }}
LAST_NAME_FIRST={{ huly_last_name_first }}

# Redpanda configuration.
REDPANDA_ADMIN_USER={{ huly_redpanda_admin_user }}
REDPANDA_ADMIN_PWD={{ huly_redpanda_admin_password }}

# CockroachDB configuration.
CR_DATABASE={{ huly_cr_database }}
CR_USERNAME={{ huly_cr_username }}
CR_USER_PASSWORD={{ huly_cr_user_password }}
CR_DB_URL=postgres://{{ huly_cr_username }}:{{ huly_cr_user_password }}@cockroach:26257/{{ huly_cr_database }}

# Optional custom data paths (left empty for default Docker named volumes).
VOLUME_ELASTIC_PATH={{ huly_volume_elastic_path }}
VOLUME_FILES_PATH={{ huly_volume_files_path }}
VOLUME_CR_DATA_PATH={{ huly_volume_cr_data_path }}
VOLUME_CR_CERTS_PATH={{ huly_volume_cr_certs_path }}
VOLUME_REDPANDA_PATH={{ huly_volume_redpanda_path }}

# Auto-generated secrets (do not edit manually).
SECRET={{ huly_secret }}
