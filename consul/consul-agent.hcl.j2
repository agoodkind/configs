datacenter = "{{ consul_datacenter }}"
domain = "{{ consul_domain }}"
data_dir = "{{ consul_data_dir }}"

bind_addr = "{{ '{{' }} GetAllInterfaces | include \"name\" \"{{ consul_bind_interface }}\" | include \"type\" \"IPv6\" | attr \"address\" {{ '}}' }}"

retry_join = ["{{ consul_server_address }}"]

server = false
client_addr = "::1"
enable_local_script_checks = true

log_level = "INFO"
enable_syslog = false
