datacenter = "{{ consul_datacenter }}"
domain = "{{ consul_domain }}"
data_dir = "{{ consul_data_dir }}"

bind_addr = "{% raw %}{{ GetAllInterfaces | include \"name\" \"{% endraw %}{{ consul_bind_interface }}{% raw %}\" | include \"type\" \"IPv6\" | attr \"address\" }}{% endraw %}"

retry_join = ["{{ consul_server_address }}"]

server = false
client_addr = "::1"
enable_local_script_checks = true

log_level = "INFO"
enable_syslog = false
