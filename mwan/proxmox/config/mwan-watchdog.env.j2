#!/bin/sh
# Generated by Ansible
#
# MWAN Watchdog environment (Proxmox-side)
# Sourced by /usr/local/bin/mwan-watchdog.sh

# MWAN VM configuration
MWAN_VMID={{ mwan_vmid }}

# Watchdog behavior
DEPLOY_WINDOW_MINUTES={{ mwan_watchdog_deploy_window_minutes | default(30) }}
CONNECTIVITY_TIMEOUT_SECONDS={{ mwan_watchdog_connectivity_timeout | default(60) }}
CHECK_INTERVAL_HEALTHY={{ mwan_watchdog_check_interval_healthy | default(30) }}
CHECK_INTERVAL_DEGRADED={{ mwan_watchdog_check_interval_degraded | default(10) }}
ALERT_COOLDOWN_SECONDS={{ mwan_watchdog_alert_cooldown | default(300) }}

# Logging
LOG_FILE={{ mwan_watchdog_log_file | default('/var/log/mwan-watchdog.log') }}
ROLLBACK_STATE_FILE={{ mwan_watchdog_state_file | default('/run/mwan-rollback.state') }}

# Email notifications
ALERT_EMAIL={{ mwan_email_recipient }}
SMTP2GO_API_KEY={{ mwan_smtp2go_api_key }}
