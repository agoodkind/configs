# Simulated Monkeybrains WAN
# In production: DHCP IPv4 (public), SLAAC IPv6, DHCPv6-PD (unreliable)
# In testbed: static IPv4, IPv6 RA from suburban

[Match]
Name=enmbrains0

[Network]
DHCP=no
IPv6AcceptRA=yes
IPv4Forwarding=yes
IPv6Forwarding=yes

[Address]
Address=10.240.206.2/24

[Route]
Gateway=10.240.206.1
Table=300

[DHCPv6]
UseDelegatedPrefix=no

[IPv6AcceptRA]
RouteMetric=5000
