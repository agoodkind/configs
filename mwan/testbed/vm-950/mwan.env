# MWAN testbed environment (mirrors production mwan.env)
# Deploy to: /etc/mwan/mwan.env on VM 950

# Interface names (stable, set by link files)
MWAN_MGMT_IFACE=enmgmt0
MWAN_WEBPASS_IFACE=enwebpass0
MWAN_ATT_VLAN_IFACE=enatt0
MWAN_MONKEYBRAINS_IFACE=enmbrains0
MWAN_INTERNAL_IFACE=enmwanbr0

# In production, AT&T uses a VLAN subinterface. In testbed, direct NIC.
# MWAN_ATT_VLAN_ID=3242  # not used in testbed

# Internal prefix (NPT source)
MWAN_INTERNAL_PREFIX=3d06:bad:b01:210::/60

# NPT target prefixes (simulated PD from each ISP)
MWAN_NPT_ATT_PREFIX=3d06:bad:b01:230::/60
MWAN_NPT_WEBPASS_PREFIX=3d06:bad:b01:220::/60
MWAN_NPT_MONKEYBRAINS_PREFIX=3d06:bad:b01:240::/60

# PD prefixes (same as NPT targets in testbed since we control them)
MWAN_PD_ATT_PREFIX=3d06:bad:b01:230::/60
MWAN_PD_WEBPASS_PREFIX=3d06:bad:b01:220::/60
MWAN_PD_MONKEYBRAINS_PREFIX=3d06:bad:b01:240::/60

# Routing table IDs
MWAN_RT_ATT=100
MWAN_RT_WEBPASS=200
MWAN_RT_MONKEYBRAINS=300

# OPNsense addresses on mwanbr
MWAN_OPNSENSE_WAN_LL=fe80::FILL_AFTER_OPNSENSE_BOOT
MWAN_OPNSENSE_EDGE_IPV6=3d06:bad:b01:201::2
MWAN_MWANBR_EDGE_IPV6=3d06:bad:b01:201::1

# Health check targets
MWAN_HEALTH_ATT_TARGETS_V4="1.1.1.1 8.8.8.8"
MWAN_HEALTH_ATT_TARGETS_V6="2606:4700:4700::1111 2001:4860:4860::8888"
MWAN_HEALTH_ATT_HTTP_TARGETS="https://ifconfig.co/ip"
MWAN_HEALTH_ATT_PING_COUNT=3
MWAN_HEALTH_ATT_SUCCESS_THRESHOLD=2
MWAN_HEALTH_ATT_CHECK_INTERVAL=10
MWAN_HEALTH_ATT_FAILURE_THRESHOLD=2
MWAN_HEALTH_ATT_RECOVERY_THRESHOLD=2

MWAN_HEALTH_WEBPASS_TARGETS_V4="1.1.1.1 8.8.8.8"
MWAN_HEALTH_WEBPASS_TARGETS_V6="2606:4700:4700::1111 2001:4860:4860::8888"
MWAN_HEALTH_WEBPASS_HTTP_TARGETS="https://ifconfig.co/ip"
MWAN_HEALTH_WEBPASS_PING_COUNT=3
MWAN_HEALTH_WEBPASS_SUCCESS_THRESHOLD=2
MWAN_HEALTH_WEBPASS_CHECK_INTERVAL=10
MWAN_HEALTH_WEBPASS_FAILURE_THRESHOLD=2
MWAN_HEALTH_WEBPASS_RECOVERY_THRESHOLD=2

MWAN_HEALTH_MONKEYBRAINS_TARGETS_V4="1.1.1.1 8.8.8.8"
MWAN_HEALTH_MONKEYBRAINS_TARGETS_V6="2606:4700:4700::1111 2001:4860:4860::8888"
MWAN_HEALTH_MONKEYBRAINS_HTTP_TARGETS="https://ifconfig.co/ip"
MWAN_HEALTH_MONKEYBRAINS_PING_COUNT=5
MWAN_HEALTH_MONKEYBRAINS_SUCCESS_THRESHOLD=1
MWAN_HEALTH_MONKEYBRAINS_CHECK_INTERVAL=30
MWAN_HEALTH_MONKEYBRAINS_FAILURE_THRESHOLD=5
MWAN_HEALTH_MONKEYBRAINS_RECOVERY_THRESHOLD=3

# Email
MWAN_EMAIL_ENABLED=1
MWAN_EMAIL_RECIPIENT=alex@goodkind.io
MWAN_EMAIL_SCRIPT=/opt/scripts/send-email
MWAN_EMAIL_FROM=alerts-testbed@goodkind.io
MWAN_EMAIL_SENDER_NAME=MWAN-TESTBED

# Debug
MWAN_DEBUG_LOGGING=1
MWAN_DEBUG_LOG=/var/log/mwan-debug.log
MWAN_TRACE_FILE=/run/mwan-trace-id
