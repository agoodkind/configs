# /etc/network/interfaces on prod LXC 116 (mwan-failover)
#
# Mirrors the testbed pattern at mwan/testbed/lxc-100/interfaces. The post-up
# IPv6 route ensures de-NATted return packets bound for any OPNsense LAN VLAN
# (under the 3d06:bad:b01::/56 umbrella) go back through OPNsense's WAN
# address (3d06:bad:b01:fe::2) on eth1, instead of leaking out the management
# interface (eth0). Without this route the LXC depends on RA from VM 113;
# if RA stops (or keepalived gets removed in cutover2 phase 5) failover
# silently breaks for IPv6.

auto lo
iface lo inet loopback

auto eth0
iface eth0 inet dhcp

auto eth1
iface eth1 inet static
	address 10.250.250.4/29
	post-up ip -4 route replace 10.250.0.0/16 via 10.250.250.2 dev eth1

iface eth1 inet6 static
	address 3d06:bad:b01:fe::4/64
	post-up ip -6 route replace 3d06:bad:b01::/56 via 3d06:bad:b01:fe::2 dev eth1
