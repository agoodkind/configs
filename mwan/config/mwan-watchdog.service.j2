[Unit]
Description={{ mwan_watchdog_unit_description | default('MWAN Auto-Rollback Watchdog') }}
After=network.target
Wants=network.target

[Service]
Type=simple
# All secrets and config live in /etc/mwan/config.toml. The Go binary reads
# them directly (Ansible vault writes config.toml with vault-encrypted values).
ExecStart=/usr/local/bin/mwan watchdog
Restart=always
RestartSec=10
# Run as root to access qm commands and VM control
User=root
Group=root
# No long timeout: watchdog should run continuously
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
