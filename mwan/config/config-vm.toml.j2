# MWAN runtime config
# Rendered by Ansible, deployed to /etc/mwan/config.toml

hostname = "{{ mwan_config_hostname }}"
mwan_vmid = "{{ mwan_vmid }}"
mwan_mgmt_addr = "{{ mwan_config_mgmt_addr }}"

[email]
smtp2go_api_key = "{{ vault_smtp2go_api_key }}"
alert_email = "{{ mwan_email_recipient }}"
from = "{{ mwan_email_from }}"
subject_prefix = "{{ mwan_email_subject_prefix }}"
bind_iface = "{{ mwan_email_bind_iface }}"
min_level = "{{ mwan_email_min_level }}"
cooldown = "{{ mwan_email_cooldown }}"

[pve]
base_url = "https://[::1]:8006/api2/json"
node = "{{ mwan_proxmox_node }}"
token_id = "{{ mwan_watchdog_pve_token_id }}"
token_secret = "{{ vault_suburban_testbed_pve_token_secret if mwan_environment == 'testbed' else vault_mwan_watchdog_pve_token_secret }}"

[network]
ping_target_ipv4 = "1.1.1.1"
ping_target_ipv6 = "2606:4700:4700::1111"
ping_targets = ["2606:4700:4700::1111", "2001:4860:4860::8888"]
curl_target = "https://ifconfig.co/ip"
last_deploy_path = "/var/lib/mwan/last-deploy"
last_change_path = "/var/run/mwan-last-change"

[[network.wan_interfaces]]
name = "enwebpass0"

[[network.wan_interfaces]]
name = "enmbrains0"

[watchdog]
service_name = "{{ mwan_watchdog_service_name }}"
deploy_window_minutes = 30
connectivity_timeout_seconds = 60
check_interval_healthy_seconds = 30
check_interval_degraded_seconds = 10
post_rollback_grace_seconds = 120
alert_cooldown_seconds = 300
deploy_grace_period_seconds = 60
max_rollback_attempts = 3
snapshot_healthy_threshold = 20
max_known_good_snapshots = 3
hash_check_every_n_healthy = 10
min_snapshot_interval_seconds = 300
max_total_snapshots = 15
vsock_cid = {{ mwan_vmid }}
vsock_port = 50051
mwan_agent_tcp_addr = "{{ mwan_watchdog_agent_tcp_addr }}"
log_file = "{{ mwan_watchdog_log_file }}"
json_log_file = "{{ mwan_watchdog_json_log_file }}"
rollback_state_file = "{{ mwan_watchdog_state_file }}"
rollback_lock_file = "{{ mwan_watchdog_lock_file }}"

[failover]
lxc_id = "{{ failover_lxc_id }}"

[opnsense]
url = "https://{% if ':' in opnsense_addr and not opnsense_addr.startswith('[') %}[{{ opnsense_addr }}]{% else %}{{ opnsense_addr }}{% endif %}"
api_key = "{{ vault_suburban_testbed_opnsense_api_key if mwan_environment == 'testbed' else vault_prod_opnsense_api_key }}"
api_secret = "{{ vault_suburban_testbed_opnsense_api_secret if mwan_environment == 'testbed' else vault_prod_opnsense_api_secret }}"
insecure = true
gateway_names = {{ opnsense_gateway_names | to_json }}

[opnsense.bgp]
router_id = "{{ opnsense_bgp_router_id }}"
firewall_source_v4 = "{{ opnsense_bgp_firewall_source_v4 }}"
firewall_source_v6 = "{{ opnsense_bgp_firewall_source_v6 }}"

{% for neighbor in opnsense_bgp_neighbors %}
[[opnsense.bgp.neighbors]]
address = "{{ neighbor.address }}"
description = "{{ neighbor.description }}"
preference = "{{ neighbor.preference }}"

{% endfor %}
[agent]
vsock_port = 50051
tcp_addr = "[::]:50052"
deploy_file = "/var/lib/mwan/last-deploy"
deploy_expected = true
log_file = "/var/log/mwan-agent.log"
debug = false

[bgp]
enabled = true
asn = {{ bgp_asn }}
router_id = "{{ bgp_router_id }}"
next_hop_v6 = "{{ bgp_next_hop_v6 }}"
keepalive_seconds = {{ bgp_keepalive_seconds }}
hold_seconds = {{ bgp_hold_seconds }}
listen_port = {{ bgp_listen_port }}

{% for neighbor in bgp_neighbors %}
[[bgp.neighbors]]
address = "{{ neighbor }}"

{% endfor %}
{% for neighbor in bgp_neighbors_v6 %}
[[bgp.neighbors_v6]]
address = "{{ neighbor }}"

{% endfor %}
[bgp.announce]
ipv4 = {{ bgp_announce_ipv4 | to_json }}
ipv6 = {{ bgp_announce_ipv6 | to_json }}

[bgp.graceful_restart]
enabled = {{ mwan_bgp_graceful_restart_enabled | ternary('true', 'false') }}
restart_time = {{ mwan_bgp_graceful_restart_time_seconds }}
notification_enabled = {{ mwan_bgp_graceful_restart_notification_enabled | ternary('true', 'false') }}

[ifmgr]
role = "{{ mwan_ifmgr_role }}"
reconcile_interval = "60s"
log_file = "/var/log/mwan-ifmgr.log"
json_log_file = "/var/log/mwan-ifmgr.jsonl"

[ifmgr.iface.{{ mwan_ifmgr_iface_key }}]
name = "{{ mwan_ifmgr_iface_name }}"
dhcp_v4 = true
ra_solicit = true
dhcp_initial_backoff = "5s"
dhcp_max_backoff = "5m"

[ifmgr.modules.oobv6]
iface = "{{ mwan_ifmgr_iface_name }}"
oob_addr = "{{ mwan_ifmgr_oob_addr }}"
oob_table_id = 500

[ifmgr.modules.oobv4]
iface = "{{ mwan_ifmgr_iface_name }}"
oob_table_id = 500

[ifmgr.modules.ra_lost]
iface = "{{ mwan_ifmgr_iface_name }}"
ra_lost_alert_after = "5m"

{% if mwan_ifmgr_wan_enabled | bool %}
[ifmgr.modules.wan_routes]
internal_iface = "{{ mwan_internal_iface }}"
opnsense_wan_ll = "{{ mwan_opnsense_wan_ll }}"
opnsense_edge_v6 = "{{ mwan_opnsense_edge_ipv6 }}"
internal_prefix = "{{ mwan_internal_prefix }}"
internal_net_v4 = "{{ mwan_internal_net_v4 }}"
health_state_file = "{{ mwan_ifmgr_wan_health_state_file }}"
shadow_mode = {{ mwan_ifmgr_wan_shadow_mode | ternary('true', 'false') }}

[[ifmgr.modules.wan_routes.wan]]
name = "att"
iface = "{{ mwan_att_iface }}{% if mwan_att_vlan_id %}.{{ mwan_att_vlan_id }}{% endif %}"
table_id = {{ mwan_rt_tables.att }}
fw_mark = {{ mwan_ifmgr_wan_fw_marks.att }}
fw_mark_prio = {{ mwan_ifmgr_wan_fw_mark_prios.att }}
from_prio = {{ mwan_ifmgr_wan_from_prios.att }}
npt_prefix = "{{ mwan_npt_att_prefix }}"

[[ifmgr.modules.wan_routes.wan]]
name = "webpass"
iface = "{{ mwan_webpass_iface }}"
table_id = {{ mwan_rt_tables.webpass }}
fw_mark = {{ mwan_ifmgr_wan_fw_marks.webpass }}
fw_mark_prio = {{ mwan_ifmgr_wan_fw_mark_prios.webpass }}
from_prio = {{ mwan_ifmgr_wan_from_prios.webpass }}
npt_prefix = "{{ mwan_npt_webpass_prefix }}"

[[ifmgr.modules.wan_routes.wan]]
name = "monkeybrains"
iface = "{{ mwan_monkeybrains_iface }}"
table_id = {{ mwan_rt_tables.monkeybrains }}
fw_mark = {{ mwan_ifmgr_wan_fw_marks.monkeybrains }}
fw_mark_prio = {{ mwan_ifmgr_wan_fw_mark_prios.monkeybrains }}
from_prio = {{ mwan_ifmgr_wan_from_prios.monkeybrains }}
npt_prefix = "{{ mwan_npt_monkeybrains_prefix }}"

{% endif %}
{% if mwan_ifmgr_host_ipv6_policy_enabled %}
[ifmgr.modules.host_ipv6_policy]
missing_iface_grace_period = "{{ mwan_ifmgr_host_ipv6_missing_iface_grace_period }}"

[[ifmgr.modules.host_ipv6_policy.interface]]
name = "{{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.name }}"
accept_ra = {{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.accept_ra }}
autoconf = {{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.autoconf | ternary('true', 'false') }}
accept_ra_defrtr = {{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.accept_ra_defrtr | ternary('true', 'false') }}
solicit_ra = {{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.solicit_ra | ternary('true', 'false') }}
cleanup_ra_default = {{ mwan_ifmgr_host_ipv6_allowed_ra_uplink.cleanup_ra_default | ternary('true', 'false') }}

{% for iface in mwan_ifmgr_host_ipv6_denied_ra_ifaces %}
[[ifmgr.modules.host_ipv6_policy.interface]]
name = "{{ iface }}"
accept_ra = 0
autoconf = false
accept_ra_defrtr = false
solicit_ra = false
cleanup_ra_default = true

{% endfor %}
{% endif %}
# The MWAN VM has no cloudflared-oob tunnel; that runs on the hypervisor host
# (config-host.toml.j2). Only the VM's own OOB-source policy rule belongs here.
[[ifmgr.modules.policy_rules.rule]]
family = "inet6"
priority = 6
from = "{{ mwan_ifmgr_policy_from_v6 }}"
table = "oob"
table_id = 500

{% if mwan_ifmgr_cloudflared_tap_enabled | bool %}
[ifmgr.modules.cloudflared_tap]
unit = "{{ mwan_ifmgr_cloudflared_tap_unit }}"
downgrade_patterns = {{ mwan_ifmgr_cloudflared_tap_downgrade_patterns | to_json }}
{% endif %}

{% if mwan_ifmgr_wg_enabled | bool %}
[ifmgr.modules.wg]
ssh_host = "{{ mwan_ifmgr_wg_ssh_host }}"
identity_file = "{{ mwan_ifmgr_wg_identity_file }}"
iface = "{{ mwan_ifmgr_wg_iface }}"
sudo = {{ mwan_ifmgr_wg_sudo | ternary('true', 'false') }}
warn_handshake_age = "{{ mwan_ifmgr_wg_warn_handshake_age }}"
error_handshake_age = "{{ mwan_ifmgr_wg_error_handshake_age }}"
timeout = "{{ mwan_ifmgr_wg_timeout }}"
ignore_peers = {{ mwan_ifmgr_wg_ignore_peers | to_json }}
{% endif %}
