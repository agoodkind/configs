# AT&T WAN Interface (testbed: static v4, DHCPv6-PD, no VLAN)
# Generated by Ansible
# Production uses 802.1X + VLAN 3242. Testbed has direct link to ISP LXC
# with static IPv4 and DHCPv6-PD (same data plane pattern, simpler L2).

[Match]
Name={{ mwan_att_iface }}

[Network]
Address={{ mwan_att_ipv4 }}
DHCP=ipv6
IPv6AcceptRA=yes
IPv4Forwarding=yes
IPv6Forwarding=yes

[DHCPv6]
PrefixDelegationHint=::/60

[Route]
Gateway={{ mwan_att_gateway }}
Metric=20

[Route]
Gateway={{ mwan_att_gateway }}
Table={{ mwan_rt_tables.att }}

[RoutingPolicyRule]
From={{ mwan_att_ipv4_addr }}
Table={{ mwan_rt_tables.att }}
Priority=100
