# AT&T WAN Interface (testbed: dynamic DHCPv4 link + DHCPv6-PD, no VLAN)
# Generated by Ansible
# NOTE: prod counterpart is mwan/networkd/21-att-vlan.network.j2 (VLAN 3242).
# Production AT&T is a dynamic DHCP link (after 802.1X on the VLAN) over which
# AT&T routes a static /29. The testbed cannot reproduce 802.1X/VLAN, so this is
# a direct link to the ISP LXC, but the addressing matches prod: DHCPv4 (pinned
# to a stable address by the sim's MAC reservation) plus DHCPv6-PD. The gateway
# and policy rules are learned/programmed at runtime by update-routes.sh, so
# there is no static [Route] or [RoutingPolicyRule] here (mirrors prod).

[Match]
Name={{ mwan_att_iface }}

[Network]
DHCP=yes
IPv6AcceptRA=yes
IPv4Forwarding=yes
IPv6Forwarding=yes

[DHCPv4]
# Secondary WAN: main-table default less preferred than Webpass (metric 10).
RouteMetric=20

[DHCPv6]
UseDelegatedPrefix=yes
PrefixDelegationHint=::/60
WithoutRA=solicit
