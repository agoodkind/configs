# Webpass WAN Interface (testbed: static v4, DHCPv6-PD)
# Generated by Ansible
# NOTE: prod counterpart at mwan/networkd/20-webpass.network.j2 (no DHCPv6-PD, just NPT). Edit both.
# Mirrors production pattern: static IPv4 + DHCPv6-PD from ISP LXC.

[Match]
Name={{ mwan_webpass_iface }}

[Network]
Address={{ mwan_webpass_ipv4 }}
DHCP=ipv6
IPv6AcceptRA=yes
IPv4Forwarding=yes
IPv6Forwarding=yes

[DHCPv6]
# Prod Webpass is delegated a /56 (NPT uses its first /60).
PrefixDelegationHint=::/56
{% if mwan_webpass_duid_raw_data %}
DUIDType=link-layer-time
DUIDRawData={{ mwan_webpass_duid_raw_data }}
{% endif %}

[Route]
Gateway={{ mwan_webpass_gateway }}
Metric=10

[Route]
Gateway={{ mwan_webpass_gateway }}
Table={{ mwan_rt_tables.webpass }}

{% if (not (mwan_ifmgr_wan_enabled | bool)) or (mwan_ifmgr_wan_shadow_mode | bool) %}
[RoutingPolicyRule]
# Only emitted when @wan is NOT authoritative (disabled or shadow). Once @wan is
# authoritative it owns this pin at from_prio (config-vm.toml.j2 v4_source), so
# networkd drops it here to avoid colliding at priority 200.
From={{ mwan_webpass_ipv4_addr }}
Table={{ mwan_rt_tables.webpass }}
Priority=200
{% endif %}
