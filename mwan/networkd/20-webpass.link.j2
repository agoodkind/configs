# Webpass WAN Interface (I226-V passthrough, igc driver)
# Generated by Ansible
# NOTE: testbed counterpart at mwan/networkd/testbed/20-webpass.link.j2 (matches by MAC). Edit both.
# Matches on igc driver, assigns name eth2 and spoofs MAC for Webpass

[Match]
Driver=igc

[Link]
Name=enwebpass0
# CRITICAL: Set MAC to Webpass-registered address
MACAddress={{ mwan_webpass_mac }}
