<?xml version="1.0"?>
<opnsense>
  <system>
    <hostname>router</hostname>
    <domain>home.goodkind.io</domain>
  </system>
  <interfaces>
    <wan>
      <if>iavf0</if>
      <ipaddr>10.250.250.2</ipaddr>
      <ipaddrv6>3d06:bad:b01:fe::2</ipaddrv6>
    </wan>
    <opt9>
      <if>iavf0</if>
      <descr>MANAGEMENT</descr>
      <ipaddr>10.250.4.1</ipaddr>
      <ipaddrv6>3d06:bad:b01:4::1</ipaddrv6>
    </opt9>
  </interfaces>
  <vlans>
    <vlan>
      <if>iavf0</if>
      <tag>200</tag>
      <descr>GeneralVLAN</descr>
    </vlan>
    <vlan>
      <if>iavf0</if>
      <tag>64</tag>
      <descr>IPv6OnlyVLAN</descr>
    </vlan>
    <vlan>
      <if>iavf0</if>
      <tag>100</tag>
      <descr>PrivilegedVLAN</descr>
    </vlan>
    <vlan>
      <if>iavf0</if>
      <tag>300</tag>
      <descr>CaptiveVLAN</descr>
    </vlan>
  </vlans>
  <nat>
    <outbound>
      <rule>
        <source_networks>10.250.0.0/24</source_networks>
      </rule>
    </outbound>
  </nat>
  <OPNsense>
    <wireguard>
      <client>
        <clients>
          <client uuid="aaa-bbb">
            <name>prod-peer-1</name>
            <pubkey>PRODKEY1</pubkey>
          </client>
          <client uuid="ccc-ddd">
            <name>prod-peer-2</name>
            <pubkey>PRODKEY2</pubkey>
          </client>
        </clients>
      </client>
    </wireguard>
  </OPNsense>
</opnsense>
