options {
    directory "/var/cache/bind";

    // Enable recursion
    recursion yes;
    allow-query { any; };

    // Forward queries to upstream
    forwarders {
        {{ dns64_upstream_dns }};
    };
    forward only;

    // DNSSEC validation
    dnssec-validation auto;

    // Network listeners - IPv6 only as requested
    listen-on-v6 { any; };
    listen-on { none; };

    // DNS64 Configuration
    dns64 {{ dns64_prefix }} {
        clients { any; };
        break-dnssec yes;
{% if dns64_force_synth | default(false) | bool %}
        // Force synthesis even when the upstream returns a native AAAA. Used
        // on segments where native IPv6 to the public internet does not
        // work, so every name has to route through the NAT64 translator.
        exclude { any; };
{% endif %}
    };
};
